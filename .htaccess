# Serve JSON (and friends) compressed — the calendar manifest is 8.4 MB raw
# and ~10x smaller gzipped; without this the gateway transit pays full price.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE application/json text/html text/css application/javascript image/svg+xml
</IfModule>

# Never serve a stale app: browsers must revalidate JS and JSON on each
# load (cheap 304s when unchanged). Found the hard way — a phone silently
# tested yesterday's bundle (C.2).
<IfModule mod_headers.c>
  <FilesMatch "\.(js|json)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
